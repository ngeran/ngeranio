# NOTE: gitignore has NO inline comments — a trailing "# ..." on a pattern line
# becomes part of the pattern and silently breaks it (e.g. "node_modules/  # ..."
# matches nothing). Keep every comment on its OWN line, above the pattern.

# ============================================
# Build Outputs (NEVER commit these)
# ============================================
# Hugo build output - syncs to Cloudflare Pages
public/
# Hugo generated files and cache
resources/_gen/
# Hugo build lock file
.hugo_build.lock

# ============================================
# Logs & Temporary Files
# ============================================
# Automation logs
logs/
# Log files
*.log
# Temporary files
tmp/
temp/
*.tmp

# ============================================
# Environment & Configuration
# ============================================
# Environment variables (API tokens, secrets)
.env
# Local environment overrides
.env.local
.env.*.local

# ============================================
# Dependencies
# ============================================
# Node.js dependencies
node_modules/
# Python virtual environments
.venv/
venv/
# Editor / OS
.vscode/
.DS_Store
*.swp
*~

# Hugo dev server (Docker) — dev container state
.dev/

# ============================================
# Cloudflare & Deployment (Safety)
# ============================================
# Never commit files that could auto-deploy and break the site
.wrangler/
.cloudflare/
.functions/
dist/

# ============================================
# AI & Assistant Tools
# ============================================
# Claude Code (Anthropic)
CLAUDE.md
.claude/

# Other AI Assistants
.cursorrules
.cursor/
.copilot-instructions.md
.ai-content-template.md
AI_AGENT_GUIDE.md

# General AI patterns — anchored to repo root (/) so they catch stray AI-tool
# files at the top level WITHOUT swallowing real project files in subdirs
# (e.g. scripts/ai-content-manager.sh, which must stay tracked).
# Any root-level file with "claude" in the name
/*claude*
# Any root-level file starting with "ai-"
/*ai-*
/.ai-*

# ============================================
# Nix / Pipeline Build Artifacts
# ============================================
# nix build out-link (OCI image tarball)
result
# parallel nix builds
result-*
# direnv / nix-direnv cache
.direnv/

# ============================================
# Documentation (Root Directory)
# ============================================
# Ignore all .md files in root directory except README.md
/*.md
!/README.md
